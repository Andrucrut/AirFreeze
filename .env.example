# Скопируй в .env и подставь свои значения (файл .env в репозиторий не коммитить).
#
# Где что задавать:
# • Локально — переменные в файле .env (этот пример → cp .env.example .env).
# • Render / другой хостинг — только в панели: Web Service → Environment (не в коде и не в Git).

# Application
APP_NAME=AirFreeze
DEBUG=false

# Public API URL used in OpenAPI/Swagger server list
# For Render: https://airfreeze-api.onrender.com
API_BASE_URL=http://localhost:8000

# PostgreSQL (обязательно драйвер asyncpg для этого проекта)
# Локально с docker compose: порт часто 5433, см. docker-compose.yml
# Render: Internal или External URL из панели Postgres, префикс postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://airfreeze:airfreeze@localhost:5433/airfreeze

# JWT (use long random secret in production)
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Business: freeze duration in hours
FREEZE_TTL_HOURS=24
FREEZE_FEE_RUB=30

# Daily dynamic pricing (absolute RUB delta, random sign +/- once per day)
DAILY_PRICE_CHANGE_MIN_RUB=50
DAILY_PRICE_CHANGE_MAX_RUB=200

# Optional: first registration with this exact email (lowercased) gets is_admin=true
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Продакшен (Render/Vercel и т.д.): URL фронта через запятую, иначе только localhost:3000
# CORS_ORIGINS=https://my-app.vercel.app,https://www.example.com
